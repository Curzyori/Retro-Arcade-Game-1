{
  "name": "zafkiel-arcade",
  "version": "1.0.0",
  "description": "Retro Arcade Game - Emperor of Time",
  "main": "interface/api/server.js",
  "scripts": {
    "start": "node interface/api/server.js",
    "dev:backend": "nodemon interface/api/server.js",
    "dev:frontend": "cd interface/web && npm run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "cd interface/web && npm run build"
  },
  "dependencies": {
    "better-sqlite3": "^11.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.0.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "winston": "^3.15.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.7",
    "concurrently": "^9.1.0"
  }
}
